# Homebrew daily maintenance: upgrade, sanity-check, cleanup
brewup() {
  emulate -L zsh
  setopt pipefail

  print -P "\n%F{cyan}==> brew upgrade%f"
  if ! command brew upgrade; then
    print -P "%F{red}brew upgrade failed%f"
    return 1
  fi

  print -P "\n%F{cyan}==> brew doctor%f"
  if ! command brew doctor; then
    print -P "%F{yellow}brew doctor reported issues (non-fatal)%f"
  fi

  print -P "\n%F{cyan}==> brew cleanup%f"
  command brew cleanup

  print -P "\n%F{green}Done.%f\n"
}

# Auto-run brewup once per day when starting a shell
BREWUP_STAMP="$HOME/.cache/brewup.last"
mkdir -p "$HOME/.cache"

if [[ ! -f "$BREWUP_STAMP" || "$(date +%F)" != "$(cat "$BREWUP_STAMP" 2>/dev/null)" ]]; then
  brewup && date +%F >| "$BREWUP_STAMP"
fi
export PATH="$HOME/.cargo/bin:$PATH"

