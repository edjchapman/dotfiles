# Path to your oh-my-zsh installation.
export ZSH=~/.oh-my-zsh

export DEFAULT_USER=$USER

export ZSH_THEME="agnoster"

# Command auto-correction.
export ENABLE_CORRECTION="true"

export HIST_STAMPS="yyyy-mm-dd"

export plugins=(
    git
    python
    virtualenv
    pip
    brew
)

source $ZSH/oh-my-zsh.sh

eval $(thefuck --alias)

# Set CLICOLOR if you want Ansi Colors in iTerm2
export CLICOLOR=1

# Set colors to match iTerm2 Terminal Colors
export TERM=xterm-256color

# PATH
export PATH="/usr/local/sbin:$HOME/bin:/usr/local/bin:$PATH"
export PATH="$PATH:$HOME/.local/bin"

# Completions (homebrew + custom)
fpath=(~/.zfunc $fpath)
if type brew &>/dev/null; then
    FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
fi
autoload -Uz compinit
compinit

# iTerm2 shell integration (installed on first launch of iTerm2)
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh" || true

# NVM (Node Version Manager) — install via: curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/HEAD/install.sh | bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# MySQL — paths for mysql@8.0 (installed via Brewfile)
export PATH="/opt/homebrew/opt/mysql@8.0/bin:$PATH"
export LDFLAGS="-L/opt/homebrew/opt/mysql@8.0/lib"
export CPPFLAGS="-I/opt/homebrew/opt/mysql@8.0/include"

# Machine-specific secrets and credentials (AWS, GitHub, Jira, etc.)
# Managed by chezmoi (encrypted_dot_zshrc.local.age)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# Windsurf
export PATH="$HOME/.codeium/windsurf/bin:$PATH"

# Sync with origin and safely clean up stale branches
hub-sync-clean() {
  echo "Syncing with origin..."
  hub sync
  git fetch --prune

  echo "Checking for branches whose remote no longer exists..."
  local -a gone_branches
  gone_branches=("${(@f)$(git branch -vv | awk '/: gone]/{print $1}')}")

  if [[ ${#gone_branches[@]} -eq 0 || -z "${gone_branches[1]}" ]]; then
    echo "No stale branches to remove."
    return
  fi

  local merged
  merged=$(git branch --merged main)

  local -a merged_gone unmerged_gone
  for branch in "${gone_branches[@]}"; do
    if echo "$merged" | grep -qE "^[* ] ${branch}$"; then
      merged_gone+=("$branch")
    else
      unmerged_gone+=("$branch")
    fi
  done

  if [[ ${#merged_gone[@]} -gt 0 ]]; then
    echo "Merged branches (safe to delete):"
    for branch in "${merged_gone[@]}"; do
      echo "  - $branch"
    done
    echo
    read "reply?Delete these ${#merged_gone[@]} merged branches? [y/N] "
    if [[ $reply =~ ^[Yy]$ ]]; then
      for branch in "${merged_gone[@]}"; do
        git branch -d "$branch"
      done
      echo "Merged branches deleted."
    fi
  fi

  if [[ ${#unmerged_gone[@]} -gt 0 ]]; then
    echo
    echo "WARNING: Unmerged branches (remote deleted, local changes may be lost):"
    for branch in "${unmerged_gone[@]}"; do
      echo "  - $branch"
    done
    echo
    read "reply?Force delete these ${#unmerged_gone[@]} unmerged branches? [y/N] "
    if [[ $reply =~ ^[Yy]$ ]]; then
      for branch in "${unmerged_gone[@]}"; do
        git branch -D "$branch"
      done
      echo "Unmerged branches force-deleted."
    else
      echo "Unmerged branches kept."
    fi
  fi

  echo "Clean-up complete."
}

# CLAUDE
export DISABLE_AUTOUPDATER=1
export ENABLE_TOOL_SEARCH=auto:5

# Suppress Homebrew informational hints while keeping automatic updates enabled
export HOMEBREW_NO_ENV_HINTS=1

# Homebrew daily maintenance: upgrade, sanity-check, cleanup
brewup() {
  emulate -L zsh
  setopt pipefail

  print -P "\n%F{cyan}==> brew upgrade%f"
  if ! command brew upgrade; then
    print -P "%F{red}brew upgrade failed%f"
    return 1
  fi

  print -P "\n%F{cyan}==> brew doctor%f"
  if ! command brew doctor; then
    print -P "%F{yellow}brew doctor reported issues (non-fatal)%f"
  fi

  print -P "\n%F{cyan}==> brew cleanup%f"
  command brew cleanup

  print -P "\n%F{green}Done.%f\n"
}

# Auto-run brewup once per day when starting a shell
BREWUP_STAMP="$HOME/.cache/brewup.last"
mkdir -p "$HOME/.cache"

if [[ ! -f "$BREWUP_STAMP" || "$(date +%F)" != "$(cat "$BREWUP_STAMP" 2>/dev/null)" ]]; then
  brewup && date +%F >| "$BREWUP_STAMP"
fi

# Rust
export PATH="$HOME/.cargo/bin:$PATH"
