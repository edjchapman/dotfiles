# Sync with origin and safely clean up stale branches
hub-sync-clean() {
  echo "🔄 Syncing with origin..."
  hub sync
  git fetch --prune

  echo "🧹 Checking for branches whose remote no longer exists..."
  local -a gone_branches
  gone_branches=("${(@f)$(git branch -vv | awk '/: gone]/{print $1}')}")

  if [[ ${#gone_branches[@]} -eq 0 || -z "${gone_branches[1]}" ]]; then
    echo "✅ No stale branches to remove."
    return
  fi

  # Get merged branches once
  local merged
  merged=$(git branch --merged main)

  # Separate into merged and unmerged
  local -a merged_gone unmerged_gone
  for branch in "${gone_branches[@]}"; do
    if echo "$merged" | grep -qE "^[* ] ${branch}$"; then
      merged_gone+=("$branch")
    else
      unmerged_gone+=("$branch")
    fi
  done

  # Handle merged branches first (safe to delete)
  if [[ ${#merged_gone[@]} -gt 0 ]]; then
    echo "✅ Merged branches (safe to delete):"
    for branch in "${merged_gone[@]}"; do
      echo "  - $branch"
    done
    echo
    read "reply?🗑️  Delete these ${#merged_gone[@]} merged branches? [y/N] "
    if [[ $reply =~ ^[Yy]$ ]]; then
      for branch in "${merged_gone[@]}"; do
        git branch -d "$branch"
      done
      echo "✅ Merged branches deleted."
    fi
  fi

  # Handle unmerged branches (requires force delete)
  if [[ ${#unmerged_gone[@]} -gt 0 ]]; then
    echo
    echo "⚠️  Unmerged branches (remote deleted, local changes may be lost):"
    for branch in "${unmerged_gone[@]}"; do
      echo "  - $branch"
    done
    echo
    read "reply?🔥 Force delete these ${#unmerged_gone[@]} unmerged branches? [y/N] "
    if [[ $reply =~ ^[Yy]$ ]]; then
      for branch in "${unmerged_gone[@]}"; do
        git branch -D "$branch"
      done
      echo "✅ Unmerged branches force-deleted."
    else
      echo "❎ Unmerged branches kept."
    fi
  fi

  echo "✅ Clean-up complete."
}

